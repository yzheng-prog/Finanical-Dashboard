# Investment Platform — API Keys
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# All keys are used server-side only (Vercel Serverless Functions).
# Frontend code must NEVER import or reference these variables.

# Primary quote source — register at https://finnhub.io
FINNHUB_API_KEY=

# Backup quote source — register at https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# FX rates — register at https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=

# US macro rates — register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Gold/commodities (low quota, must cache) — https://metals-api.com
METALS_API_KEY=

# Backup news source — https://www.marketaux.com
MARKETAUX_API_KEY=

# Claude LLM advisor — Phase 3 feature — https://www.anthropic.com/api
ANTHROPIC_API_KEY=

# Vercel KV — auto-injected by Vercel in production; set manually for local dev
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
